{
    "positionX": "right",
    "positionY": "top",
    "control-center-margin-top": 10,
    "control-center-margin-right": 10,
    "notification-2fa-action": true,
    "widgets": [
        "title",
        "dnd",
        "mpris",
        "volume",
        "buttons-grid",
        "notifications"
    ],
